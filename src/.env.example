APP_NAME="Media Catalog POC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=oracle
DB_HOST=oracle
DB_PORT=1521
DB_SERVICE_NAME=XEPDB1
DB_DATABASE=XEPDB1
DB_USERNAME=mediacat
DB_PASSWORD=mediacat
